{
  "name": "redis-axon",
  "version": "1.2.2",
  "description": "A resilient Redis client with circuit breaker, connection pooling, cluster support, and automatic reconnection with exponential backoff.",
  "author": "Srajan Saxena",
  "license": "MIT",
  "type": "module",
  "main": "./dist/connection/connection.js",
  "types": "./dist/connection/connection.d.ts",
  "exports": {
    "./connection/connection.js": {
      "types": "./dist/connection/connection.d.ts",
      "import": "./dist/connection/connection.js"
    },
    "./connection/pool.js": {
      "types": "./dist/connection/pool.d.ts",
      "import": "./dist/connection/pool.js"
    },
    "./connection/cluster.js": {
      "types": "./dist/connection/cluster.d.ts",
      "import": "./dist/connection/cluster.js"
    },
    "./circuit/circuitBreaker.js": {
      "types": "./dist/circuit/circuitBreaker.d.ts",
      "import": "./dist/circuit/circuitBreaker.js"
    },
    "./logger.js": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./health.js": {
      "types": "./dist/health/health.d.ts",
      "import": "./dist/health/health.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/circuitBreaker.test.ts",
    "test:integration": "vitest run tests/connection.test.ts",
    "test:health": "vitest run tests/health.test.ts"
  },
  "keywords": [
    "redis",
    "ioredis",
    "circuit-breaker",
    "connection-pool",
    "cluster",
    "resilient",
    "reconnection",
    "backoff"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "dependencies": {
    "ioredis": "^5.11.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@testcontainers/redis": "^12.0.1",
    "@types/node": "^25.9.1",
    "testcontainers": "^12.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
