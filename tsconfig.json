{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": false,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "#connection/*" : ["./src/connection/*"],
      "#circuit/*" : ["./src/circuit/*"],
      "#helper/*" : ["./src/helper/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
